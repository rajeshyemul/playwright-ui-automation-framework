{
  "name": "playwright-ui-automation-framework",
  "version": "1.0.0",
  "description": "Enterprise-grade Playwright TypeScript UI automation framework with Allure reporting and step tracking",
  "main": "index.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/rajeshyemul/playwright-ui-automation-framework.git"
  },
  "bugs": {
    "url": "https://github.com/rajeshyemul/playwright-ui-automation-framework/issues"
  },
  "homepage": "https://github.com/rajeshyemul/playwright-ui-automation-framework#readme",
  "scripts": {
    "test": "npx playwright test",
    "test:smoke": "npx playwright test tests/smoke/",
    "test:regression": "npx playwright test tests/regression/",
    "test:integration": "npx playwright test tests/e2e/",
    "test:headed": "npx playwright test --headed",
    "test:debug": "npx playwright test --debug",
    "report:html": "npx ts-node src/helper/reporting/GenerateReports.ts html",
    "report:allure": "npx ts-node src/helper/reporting/GenerateReports.ts allure --open",
    "format": "prettier --write .",
    "test:parallel": "npx playwright test --workers=4",
    "test:serial": "npx playwright test --workers=1",
    "clean": "rm -rf reports test-results playwright-report allure-results",
    "clean:reports": "rm -rf reports/*",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "pretest": "npm run type-check",
    "codegen": "npx playwright codegen"
  },
  "keywords": [
    "playwright",
    "typescript",
    "ui-automation",
    "test-framework",
    "allure",
    "e2e-testing",
    "page-object-model",
    "test-automation"
  ],
  "author": "Rajesh Yemul",
  "license": "MIT",
  "type": "commonjs",
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.57.0",
    "@types/crypto-js": "^4.2.2",
    "@types/node": "^25.0.10",
    "@types/randomstring": "^1.3.0",
    "@types/string-format": "^2.0.3",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "8.53.1",
    "@typescript-eslint/parser": "8.53.1",
    "allure-js-commons": "^3.4.5",
    "allure-playwright": "^3.4.5",
    "crypto-js": "^4.2.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "pdf-parse": "^2.4.5",
    "prettier": "3.8.1",
    "randomstring": "^1.3.1",
    "string-format": "^2.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.53.1",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5",
    "xml2js": "^0.6.2"
  }
}
